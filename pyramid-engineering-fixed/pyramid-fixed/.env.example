# ============================================================
# PYRAMID ENGINEERING & CONSTRUCTION — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pyramid_construction
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Authentication
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
PUBLIC_URL=http://localhost:5000

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5500,http://localhost:5500

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@pyramid.co.tz
NOTIFY_EMAIL=admin@pyramid.co.tz

# Admin credentials (used for initial setup)
ADMIN_EMAIL=christianlema482@gmail.com
ADMIN_PASSWORD=Lema16family
ADMIN_NAME=Owner Admin

# WhatsApp
WHATSAPP_NUMBER=255XXXXXXXXX
