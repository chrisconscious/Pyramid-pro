# ============================================================
#  PYRAMID ENGINEERING — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

NODE_ENV=development
PORT=5000
API_PREFIX=/api

# PostgreSQL — update with your credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_NAME=pyramid_construction
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# CORS — add all origins where your frontend runs
CORS_ORIGIN=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# JWT — CHANGE THESE IN PRODUCTION (min 32 chars)
JWT_SECRET=change_this_to_a_very_long_random_string_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_too_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
PUBLIC_URL=http://localhost:5000

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Optional: Email notifications for contact form
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=admin@pyramidconstruction.co.tz

# Optional: OpenAI for AI chat
# OPENAI_API_KEY=sk-your-key-here
